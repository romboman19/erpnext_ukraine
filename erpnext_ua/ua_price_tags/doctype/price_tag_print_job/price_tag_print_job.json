{
 "doctype": "DocType",
 "name": "Price Tag Print Job",
 "module": "UA Price Tags",
 "autoname": "PRICE-TAG-.YYYY.-.#####",
 "title_field": "name",
 "sort_field": "creation",
 "sort_order": "DESC",
 "track_changes": 1,
 "field_order": [
  "status_section",
  "status",
  "template_type",
  "label_size",
  "print_method",
  "print_format",
  "company",
  "warehouse",
  "pricing_section",
  "price_list",
  "promotional_price_list",
  "currency",
  "source_section",
  "reason",
  "source_doctype",
  "source_name",
  "source_label",
  "reprint_of",
  "items_section",
  "items",
  "total_labels",
  "audit_section",
  "created_by_user",
  "ready_at",
  "printed_by",
  "printed_at",
  "error_message",
  "snapshot_hash"
 ],
 "fields": [
  {"fieldname": "status_section", "fieldtype": "Section Break", "label": "Пакет друку"},
  {"fieldname": "status", "fieldtype": "Select", "label": "Статус", "options": "Draft\nReady\nPrinted\nError", "default": "Draft", "reqd": 1, "in_list_view": 1, "read_only": 1},
  {"fieldname": "template_type", "fieldtype": "Select", "label": "Тип цінника", "options": "Standard\nPromotional\nPackaging", "default": "Standard", "reqd": 1, "in_list_view": 1},
  {"fieldname": "label_size", "fieldtype": "Select", "label": "Розмір", "options": "40×25 mm", "default": "40×25 mm", "reqd": 1},
  {"fieldname": "print_method", "fieldtype": "Select", "label": "Спосіб друку", "options": "PDF", "default": "PDF", "reqd": 1},
  {"fieldname": "print_format", "fieldtype": "Link", "label": "Print Format", "options": "Print Format", "reqd": 1},
  {"fieldname": "company", "fieldtype": "Link", "label": "Компанія", "options": "Company", "in_list_view": 1},
  {"fieldname": "warehouse", "fieldtype": "Link", "label": "Магазин / склад", "options": "Warehouse", "in_list_view": 1},
  {"fieldname": "pricing_section", "fieldtype": "Section Break", "label": "Зафіксоване джерело цін"},
  {"fieldname": "price_list", "fieldtype": "Link", "label": "Роздрібний прайс-лист", "options": "Price List", "reqd": 1},
  {"fieldname": "promotional_price_list", "fieldtype": "Link", "label": "Акційний прайс-лист", "options": "Price List"},
  {"fieldname": "currency", "fieldtype": "Link", "label": "Валюта", "options": "Currency", "reqd": 1},
  {"fieldname": "source_section", "fieldtype": "Section Break", "label": "Джерело"},
  {"fieldname": "reason", "fieldtype": "Select", "label": "Причина", "options": "Manual Print\nGoods Receipt\nStock Transfer\nGoods Delivery\nReturn\nInventory Selection\nPrice Change\nReprint", "default": "Manual Print", "reqd": 1, "in_list_view": 1},
  {"fieldname": "source_doctype", "fieldtype": "Link", "label": "Тип документа", "options": "DocType"},
  {"fieldname": "source_name", "fieldtype": "Dynamic Link", "label": "Документ", "options": "source_doctype"},
  {"fieldname": "source_label", "fieldtype": "Data", "label": "Опис джерела"},
  {"fieldname": "reprint_of", "fieldtype": "Link", "label": "Повторення пакета", "options": "Price Tag Print Job", "read_only": 1},
  {"fieldname": "items_section", "fieldtype": "Section Break", "label": "Цінники"},
  {"fieldname": "items", "fieldtype": "Table", "label": "Товари", "options": "Price Tag Print Job Item", "reqd": 1},
  {"fieldname": "total_labels", "fieldtype": "Int", "label": "Усього цінників", "read_only": 1},
  {"fieldname": "audit_section", "fieldtype": "Section Break", "label": "Аудит"},
  {"fieldname": "created_by_user", "fieldtype": "Link", "label": "Створив", "options": "User", "read_only": 1},
  {"fieldname": "ready_at", "fieldtype": "Datetime", "label": "Готовий до друку", "read_only": 1},
  {"fieldname": "printed_by", "fieldtype": "Link", "label": "Надрукував", "options": "User", "read_only": 1},
  {"fieldname": "printed_at", "fieldtype": "Datetime", "label": "Надруковано", "read_only": 1},
  {"fieldname": "error_message", "fieldtype": "Small Text", "label": "Помилка", "read_only": 1},
  {"fieldname": "snapshot_hash", "fieldtype": "Data", "label": "SHA-256 знімка", "hidden": 1, "read_only": 1}
 ],
 "permissions": [
  {"role": "Price Tag User", "read": 1, "write": 1, "create": 1, "print": 1},
  {"role": "Price Tag Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "print": 1, "export": 1},
  {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "print": 1, "export": 1}
 ]
}
