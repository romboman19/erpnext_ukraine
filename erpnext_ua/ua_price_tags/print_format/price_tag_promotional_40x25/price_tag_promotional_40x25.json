 "font_size": 9,
 "html": "<style>\n@page { size: 40mm 25mm; margin: 0; }\n.print-format { margin: 0 !important; padding: 0 !important; }\n.ua-price-tag { box-sizing: border-box; width: 40mm; height: 25mm; padding: .8mm 1mm .5mm; overflow: hidden; color: #000; background: #fff; font-family: DejaVu Sans, sans-serif; page-break-after: always; display: flex; flex-direction: column; }\n.ua-price-tag:last-child { page-break-after: auto; }\n.ua-price-tag .name { height: 4.4mm; overflow: hidden; font-size: 7.4pt; line-height: 1.05; white-space: nowrap; text-overflow: ellipsis; }\n.ua-price-tag .prices { height: 9.8mm; display: grid; grid-template-columns: 13mm 1fr; grid-template-rows: 3mm 6.8mm; }\n.ua-price-tag .code { grid-row: 1 / 3; align-self: end; padding-bottom: 1mm; overflow: hidden; font-size: 5.2pt; white-space: nowrap; }\n.ua-price-tag .old { justify-self: end; align-self: start; font-size: 8pt; line-height: 1; text-decoration: line-through; white-space: nowrap; }\n.ua-price-tag .new { justify-self: end; align-self: end; font-size: 19pt; font-weight: 800; line-height: .85; letter-spacing: -.4mm; white-space: nowrap; }\n.ua-price-tag .barcode-row { height: 9.4mm; display: flex; align-items: flex-end; justify-content: flex-end; }\n.ua-price-tag .barcode { width: 27mm; height: 8.2mm; object-fit: fill; }\n.ua-price-tag .barcode-text { width: 27mm; overflow: hidden; font-size: 5pt; text-align: center; white-space: nowrap; }\n</style>\n{% for row in doc.items %}{% for copy in range(row.copies|int) %}\n<div class=\"ua-price-tag\">\n  <div class=\"name\">{{ row.item_name }}{% if row.variant_text %} {{ row.variant_text }}{% endif %}</div>\n  <div class=\"prices\">\n    <div class=\"code\">{{ row.item_code }}</div>\n    <div class=\"old\">{{ (\"%.2f\"|format(row.old_price|float)).replace(\".\", \",\") }}</div>\n    <div class=\"new\">{{ (\"%.2f\"|format(row.selling_price|float)).replace(\".\", \",\") }}</div>\n  </div>\n  <div class=\"barcode-row\">{% if row.barcode_svg %}<img class=\"barcode\" src=\"{{ row.barcode_svg }}\">{% else %}<div class=\"barcode-text\">{{ row.barcode or row.item_code }}</div>{% endif %}</div>\n</div>\n{% endfor %}{% endfor %}",
 "idx": 0,
 "line_breaks": 0,
