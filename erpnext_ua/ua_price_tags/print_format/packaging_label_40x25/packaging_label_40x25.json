 "font_size": 9,
 "html": "<style>\n@page { size: 40mm 25mm; margin: 0; }\n.print-format { margin: 0 !important; padding: 0 !important; }\n.ua-price-tag { box-sizing: border-box; width: 40mm; height: 25mm; padding: 1mm 1.2mm .5mm; overflow: hidden; color: #000; background: #fff; font-family: DejaVu Sans, sans-serif; page-break-after: always; display: flex; flex-direction: column; }\n.ua-price-tag:last-child { page-break-after: auto; }\n.ua-price-tag .name { height: 6mm; overflow: hidden; font-size: 7.5pt; line-height: 1.05; text-align: center; white-space: nowrap; text-overflow: ellipsis; }\n.ua-price-tag .code { height: 3.4mm; overflow: hidden; font-size: 5.4pt; line-height: 1; white-space: nowrap; }\n.ua-price-tag .barcode-row { height: 14.1mm; display: flex; align-items: flex-end; justify-content: center; }\n.ua-price-tag .barcode { width: 29mm; height: 12.5mm; object-fit: fill; }\n.ua-price-tag .barcode-text { width: 29mm; overflow: hidden; font-size: 6pt; text-align: center; white-space: nowrap; }\n</style>\n{% for row in doc.items %}{% for copy in range(row.copies|int) %}\n<div class=\"ua-price-tag\">\n  <div class=\"name\">{{ row.item_name }}{% if row.variant_text %} {{ row.variant_text }}{% endif %}</div>\n  <div class=\"code\">{{ row.item_code }}</div>\n  <div class=\"barcode-row\">{% if row.barcode_svg %}<img class=\"barcode\" src=\"{{ row.barcode_svg }}\">{% else %}<div class=\"barcode-text\">{{ row.barcode or row.item_code }}</div>{% endif %}</div>\n</div>\n{% endfor %}{% endfor %}",
